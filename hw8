def greet(name, age):
    return f"Привіт, {name}!"

greet("Влад", 16)

@repeat(times=3)
def say_hello():
    print("Привіт, ліцеїсти!")

say_hello()

words = ["дім", "трамвай", "код", "ліцей"]
print("\nСлова довші за 4 символи:")
filter_long_words(words)

print("\nЗворотний відлік:")
for item in countdown(3):
    print(item)